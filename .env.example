# ========== Supabase (obligatoire pour BDD / Auth) ==========
# Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_cle_anon_publique

# Optionnel : uniquement côté serveur (Edge Functions, API). Ne jamais exposer au frontend.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ========== Jeu / Multiplayer ==========
# URL du serveur WebSocket (parties en ligne)
VITE_WS_URL=http://localhost:3001

# ========== Paiement Wave (Fiat) ==========
# Endpoint backend (Node / Supabase Edge...) qui crée une session de paiement Wave
# Ce endpoint ne doit PAS contenir la clé secrète côté client, il agit comme proxy sécurisé.
VITE_WAVE_CHECKOUT_URL=https://votre-backend.exemple.com/api/wave/checkout

# Clé API Wave (à configurer uniquement côté serveur, ex. Railway)
# WAVE_API_KEY=wave_live_xxx

# Secret pour vérifier la signature des webhooks Wave (sécurité callback)
# WAVE_WEBHOOK_SECRET=whsec_xxx

# URL de base de l'API Wave (laisser par défaut sauf consigne contraire de Wave)
# WAVE_API_BASE=https://api.wave.com/v1

# URL de callback (Webhook) appelée par Wave après paiement confirmé (crédit solde Supabase)
# WAVE_CALLBACK_URL=https://votre-backend.railway.app/api/wave/callback

# Supabase côté serveur (pour le callback Wave : crédit fiat_balance_cents)
# SUPABASE_URL=https://votre-projet.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (clé service_role, jamais côté client)

# ========== TON / Crypto (optionnel) ==========
# Adresse du contrat de pari TON
# VITE_TON_BET_CONTRACT=

# ========== Telegram Bot (serveur WebSocket sur Railway) ==========
# Token du bot Telegram (ne pas préfixer par VITE_, il reste côté serveur uniquement)
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF...

# URL publique de la web app (utilisée dans les boutons du bot et les liens d’invitation)
# WEB_APP_URL=https://royale-dames.vercel.app

# Origin autorisée pour le serveur WebSocket (CORS)
# CLIENT_URL=https://royale-dames.vercel.app

# ========== Build (optionnel) ==========
# Si l'app est déployée sous un sous-dossier (ex. /royale-dames/)
# VITE_BASE_PATH=/royale-dames/
